NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL=postgresql://indiasmarttrade:indiasmarttrade_dev_password@localhost:5433/indiasmarttrade?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_REFRESH_TTL=30d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3010,http://localhost:3011

# Cloudinary (uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=indiasmarttrade_screenshots

# Market data provider:
#   `multi`      Twelve Data (or Mock) for global symbols + NSE polling for Indian symbols. Recommended.
#   `twelvedata` Twelve Data for everything global; no Indian symbols.
#   `mock`       Random-walk prices for every symbol (no external dependency).
# MARKET_API_KEY is only used by twelvedata/multi for the global feed.
# Get a Twelve Data API key at https://twelvedata.com/pricing (free tier supports forex WS).
# NSE polling uses nseindia.com public endpoints — no key required.
MARKET_PROVIDER=multi
MARKET_API_KEY=

ADMIN_SETUP_SECRET=

# Auth — OTP toggle for signup. Defaults to true.
# Set AUTH_OTP_ENABLED=false during dev to skip the OTP step entirely
# (signup creates the user immediately and returns tokens). Never set false in prod.
AUTH_OTP_ENABLED=true

# Email — Resend (https://resend.com). Used for signup OTP + forgot-password OTP.
# Get a key at https://resend.com/api-keys (free tier: 100 emails/day, 3000/month).
# Leave RESEND_API_KEY blank for dev: OTP codes will print to the backend terminal.
# RESEND_FROM must use a domain you've verified in Resend's dashboard.
# `onboarding@resend.dev` is Resend's shared test sender — only delivers to the
# email address of the account that owns the API key. Swap for your own domain in prod.
RESEND_API_KEY=
RESEND_FROM="IndiaSmartTrade <onboarding@resend.dev>"
